# 环境变量配置
# 复制此文件为 .env 并填写实际值

# 数据库连接 (PostgreSQL)
# 本地: postgresql://user:password@localhost:5432/ai_streaming
# 云端 (Neon): postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/ai_streaming?sslmode=require
DATABASE_URL="postgresql://jiangyuan@localhost:5432/ai_streaming?schema=public"

# JWT 密钥 (生产环境必须修改)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# JWT 过期时间
JWT_EXPIRES_IN="7d"

# OpenAI API Key（可选，用于 AI 回复功能）
OPENAI_API_KEY=""

# 服务器端口
PORT=3001

# CORS 允许的来源（多个用逗号分隔）
# 本地开发: http://localhost:5173
# Vercel预览: https://*.vercel.app
CORS_ORIGINS="http://localhost:5173"